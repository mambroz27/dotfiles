{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "background": "transparent",
          "foreground": "p:path",
          "template": "{{ .Path }}",
          "options": {
            "style": "full"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:git-modified{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:git-diverged{{ end }}",
            "{{ if gt .Ahead 0 }}p:git-ahead{{ end }}",
            "{{ if gt .Behind 0 }}p:git-behind{{ end }}",
            "p:git"
          ],
          "background": "transparent",
          "template": " {{ .UpstreamIcon }} {{ .HEAD }}{{ if or (.Working.Changed) (.Staging.Changed) }}*{{ end }}{{ if gt .Behind 0 }}⇣{{ end }}{{ if gt .Ahead 0 }}⇡{{ end }}",
          "options": {
            "fetch_upstream_icon": true,
            "branch_icon": "",
            "commit_icon": "@",
            "fetch_status": true
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "overflow": "hidden",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:timer",
          "background": "transparent",
          "template": "{{ .FormattedMs }}",
          "options": {
            "threshold": 5000
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground_templates": [
            "{{if gt .Code 0}}p:code-err{{end}}",
            "{{if eq .Code 0}}p:system{{end}}"
          ],
          "background": "transparent",
          "template": "{{ if .WSL }}\u2771\ue62a{{ end }}{{.Icon}} \u276f"
        }
      ]
    }
  ],
  "transient_prompt": {
    "foreground_templates": [
      "{{if gt .Code 0}}p:code-err{{end}}",
      "{{if eq .Code 0}}p:code-ok{{end}}"
    ],
    "background": "transparent",
    "template": "\u276f "
  },
  "secondary_prompt": {
    "foreground": "p:system",
    "background": "transparent",
    "template": "\u276f\u276f "
  },
  "palette": {
    "system": "#c3a6ff",
    "path": "#5ccfe6",
    "git": "#bae67e",
    "git-modified": "#ffd580",
    "git-diverged": "#ffae57",
    "git-ahead": "#c3a6ff",
    "git-behind": "#c3a6ff",
    "code-ok": "#d7dce2",
    "code-err": "#ef6b73",
    "timer": "#ffae57"
  }
}
